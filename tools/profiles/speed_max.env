# Throughput-first profile for low latency and higher concurrency.

COSYVOICE_TTS_CONCURRENCY=2
COSYVOICE_MAX_TEXT_CHARS=1000
COSYVOICE_MAX_SEGMENTS=20

COSYVOICE_PROMPT_CACHE_SIZE=64
COSYVOICE_PROMPT_MAX_SECONDS=12
COSYVOICE_PROMPT_TRIM_SILENCE=True
COSYVOICE_PROMPT_SILENCE_THRESHOLD=0.01
COSYVOICE_PROMPT_NORMALIZE_PEAK=False

COSYVOICE_TOKEN_HOP_LEN=20
COSYVOICE_TOKEN_MAX_HOP_FACTOR=3
COSYVOICE_STREAM_SCALE_FACTOR=2.0
COSYVOICE_STREAM_POLL_INTERVAL=0.005

COSYVOICE_SAMPLING_TOP_K=20
COSYVOICE_MAX_TOKEN_TEXT_RATIO=18
COSYVOICE_MIN_TOKEN_TEXT_RATIO=2
COSYVOICE_VLLM_TOP_P=0.78
COSYVOICE_VLLM_TEMPERATURE=0.9
COSYVOICE_VLLM_REPETITION_PENALTY=1.06
COSYVOICE_VLLM_FREQUENCY_PENALTY=0.0
COSYVOICE_VLLM_PRESENCE_PENALTY=0.0
COSYVOICE_VLLM_STEP_SLEEP=0.0003
COSYVOICE_VLLM_GPU_MEMORY_UTILIZATION=0.9

COSYVOICE_ENABLE_TF32=True
COSYVOICE_CUDNN_BENCHMARK=True
COSYVOICE_FORCE_CUDA_GC=False
