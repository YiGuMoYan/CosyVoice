# Quality-first profile for strongest voice clone stability.
# Apply before launching vllm_server.py

COSYVOICE_TTS_CONCURRENCY=1
COSYVOICE_MAX_TEXT_CHARS=1500
COSYVOICE_MAX_SEGMENTS=28

COSYVOICE_ENABLE_TEXT_CLEAN=True
COSYVOICE_ENABLE_ZH_NUM_NORMALIZE=True
COSYVOICE_ENABLE_AUTO_BREATH=True

COSYVOICE_PROMPT_CACHE_SIZE=32
COSYVOICE_PROMPT_MAX_SECONDS=20
COSYVOICE_PROMPT_TRIM_SILENCE=True
COSYVOICE_PROMPT_SILENCE_THRESHOLD=0.008
COSYVOICE_PROMPT_NORMALIZE_PEAK=True
COSYVOICE_PROMPT_TARGET_PEAK=0.9

COSYVOICE_TOKEN_HOP_LEN=32
COSYVOICE_TOKEN_MAX_HOP_FACTOR=4
COSYVOICE_STREAM_SCALE_FACTOR=1.5
COSYVOICE_STREAM_POLL_INTERVAL=0.01

COSYVOICE_SAMPLING_TOP_K=30
COSYVOICE_MAX_TOKEN_TEXT_RATIO=22
COSYVOICE_MIN_TOKEN_TEXT_RATIO=2
COSYVOICE_VLLM_TOP_P=0.82
COSYVOICE_VLLM_TEMPERATURE=0.95
COSYVOICE_VLLM_REPETITION_PENALTY=1.08
COSYVOICE_VLLM_FREQUENCY_PENALTY=0.02
COSYVOICE_VLLM_PRESENCE_PENALTY=0.0
COSYVOICE_VLLM_STEP_SLEEP=0.0005
COSYVOICE_VLLM_GPU_MEMORY_UTILIZATION=0.85

COSYVOICE_ENABLE_TF32=True
COSYVOICE_CUDNN_BENCHMARK=True
COSYVOICE_FORCE_CUDA_GC=False
